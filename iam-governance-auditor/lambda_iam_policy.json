{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "ReadIAMForAudit",
			"Effect": "Allow",
			"Action": [
				"iam:ListUsers",
				"iam:ListAttachedUserPolicies",
				"iam:ListUserPolicies",
				"iam:GetUserPolicy",
				"iam:ListMFADevices",
				"iam:GetLoginProfile",
				"iam:ListAccessKeys",
				"iam:GetAccessKeyLastUsed"
			],
			"Resource": "*"
		},
		{
			"Sid": "ReadAllS3Buckets",
			"Effect": "Allow",
			"Action": [
				"s3:ListAllMyBuckets",
				"s3:GetBucketPolicy",
				"s3:GetBucketLocation"
			],
			"Resource": "*"
		},
		{
			"Sid": "WriteAndVerifyReportBucket",
			"Effect": "Allow",
			"Action": [
				"s3:PutObject",
				"s3:ListBucket"
			],
			"Resource": [
				"arn:aws:s3:::iam-governance-reports-rkori-2026",
				"arn:aws:s3:::iam-governance-reports-rkori-2026/*"
			]
		}
	]
}
